	writeFile(String content, String filePath)
	Writes content to a file, appending with a live timestamp and newline to imitate tasker.log();

	Arguments:
	 - content → Text to write into the file
	 - filePath → Full path of the file to write to

	Returns:
	 - true if write succeeded, false otherwise
	───────────────────────────────────────────────────────────────*/
	writeFile(String content, String filePath) {
		try {
			File file = new File(filePath);
			File parent = file.getParentFile();
			if (parent != null && !parent.exists()) {
				parent.mkdirs(); /* Create parent directories if needed */
			}

			/* Generate current timestamp: yyyy-MM-dd HH:mm:ss.SSS */
			SimpleDateFormat sdf = new SimpleDateFormat("yyyy-MM-dd HH:mm:ss.SSS");
			String timestamp = sdf.format(new Date());

			/* true -> append mode */
			FileWriter writer = new FileWriter(file, true);
			writer.write(timestamp + " " + content + "\n");
			writer.close();
			return true;
		} catch (Exception e) {
			return false;
		}
	}
