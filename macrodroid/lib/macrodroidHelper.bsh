	/*───────────────────────────────────────────────────────────────
	getPath(Context context, Uri uri)
	**Get Absolute File Path from Uri**
	Converts content Uris (including Document & Tree Uris) or file Uris
	into a standard absolute file path executable within BeanShell.
	───────────────────────────────────────────────────────────────*/
	String getPath(Context context, Uri uri) {
		if (context == null || uri == null) {
			return null;
		}

		boolean isKitKat = Build.VERSION.SDK_INT >= 19;
		boolean isLollipop = Build.VERSION.SDK_INT >= 21;

		/* Nested helper methods within the main namespace to encapsulate all logic */
		getDataColumn(Context ctx, Uri u, String sel, String[] selArgs) {
			Cursor cursor = null;
			String column = "_data";
			String[] projection = new String[] { column };
			try {
				cursor = ctx.getContentResolver().query(u, projection, sel, selArgs, null);
				if (cursor != null && cursor.moveToFirst()) {
					int index = cursor.getColumnIndexOrThrow(column);
					return cursor.getString(index);
				}
			} catch (Exception e) {
				return null;
			} finally {
				if (cursor != null) {
					cursor.close();
				}
			}
			return null;
		}

		isExternalStorageDocument(Uri u) {
			return "com.android.externalstorage.documents".equals(u.getAuthority());
		}

		isDownloadsDocument(Uri u) {
			return "com.android.providers.downloads.documents".equals(u.getAuthority());
		}

		isMediaDocument(Uri u) {
			return "com.android.providers.media.documents".equals(u.getAuthority());
		}

		isGooglePhotosUri(Uri u) {
			return "com.google.android.apps.photos.content".equals(u.getAuthority());
		}

		/* 1. Handle Tree URIs (Folders / SAF Storage Access Framework trees) */
		if (isLollipop && DocumentsContract.isTreeUri(uri)) {
			String treeId = DocumentsContract.getTreeDocumentId(uri);
			if (isExternalStorageDocument(uri) && treeId != null) {
				String[] split = treeId.split(":");
				String type = split[0];
				String pathSuffix = "";
				if (split.length > 1) {
					pathSuffix = split[1];
				}

				if ("primary".equalsIgnoreCase(type)) {
					return Environment.getExternalStorageDirectory() + "/" + pathSuffix;
				} else {
					return "/storage/" + type + "/" + pathSuffix;
				}
			}
		}

		/* 2. DocumentProvider check (Individual files) */
		if (isKitKat && DocumentsContract.isDocumentUri(context, uri)) {

			/* ExternalStorageProvider processing */
			if (isExternalStorageDocument(uri)) {
				String docId = DocumentsContract.getDocumentId(uri);
				String[] split = docId.split(":");
				String type = split[0];
				String pathSuffix = "";

				if (split.length > 1) {
					pathSuffix = split[1];
				}

				if ("primary".equalsIgnoreCase(type)) {
					return Environment.getExternalStorageDirectory() + "/" + pathSuffix;
				} else {
					return "/storage/" + type + "/" + pathSuffix;
				}
			}

			/* DownloadsProvider processing */
			if (isDownloadsDocument(uri)) {
				String id = DocumentsContract.getDocumentId(uri);
				if (id != null && id.startsWith("raw:")) {
					return id.substring(4);
				}
				try {
					Uri contentUri = ContentUris.withAppendedId(
						Uri.parse("content://downloads/public_downloads"),
						Long.valueOf(id)
					);
					return getDataColumn(context, contentUri, null, null);
				} catch (Exception ex) {
					return null;
				}
			}

			/* MediaProvider processing */
			if (isMediaDocument(uri)) {
				String docId = DocumentsContract.getDocumentId(uri);
				String[] split = docId.split(":");
				String type = split[0];

				Uri contentUri = null;
				if ("image".equals(type)) {
					contentUri = MediaStore.Images.Media.EXTERNAL_CONTENT_URI;
				} else if ("video".equals(type)) {
					contentUri = MediaStore.Video.Media.EXTERNAL_CONTENT_URI;
				} else if ("audio".equals(type)) {
					contentUri = MediaStore.Audio.Media.EXTERNAL_CONTENT_URI;
				}

				String selection = "_id=?";
				String[] selectionArgs = new String[] { split[1] };

				return getDataColumn(context, contentUri, selection, selectionArgs);
			}
		}

		/* MediaStore and generic content providers */
		if ("content".equalsIgnoreCase(uri.getScheme())) {
			if (isGooglePhotosUri(uri)) {
				return uri.getLastPathSegment();
			}
			return getDataColumn(context, uri, null, null);
		}

		/* Standard raw file protocol */
		if ("file".equalsIgnoreCase(uri.getScheme())) {
			return uri.getPath();
		}

		return null;
	}

	

