import android.view.accessibility.AccessibilityNodeInfo;
import java.util.ArrayList;
import java.util.HashMap;
import android.graphics.Point;
/*───────────────────────────────────────────────────────────────
click(...)
**Performs Click Action**
Finds a node using the provided criteria and performs a click on it
or its closest clickable parent.

Arguments:

* node → The specific node or collection to click.
* value → The text value to search for.
* key → The attribute to search by (default is "text").
* index → The instance index if multiple matches exist.
* timeout → Max time to wait for the node.
* parentLevel/sibling → Criteria for complex node location.

Returns:

* The AccessibilityNodeInfo that was clicked, or null/throws error.
───────────────────────────────────────────────────────────────*/

/* Base Click Logic */
click(AccessibilityNodeInfo node) {
	if (node == null) return null;
	boolean success;
	AccessibilityNodeInfo firstNode = node;
	/* Traverse up to find a clickable parent if the current node isn't */
	while (node != null && !node.isClickable()) {
		node = node.getParent();
	}

	if (node != null) {
		showOnScreen(node);
		debugMe(node);
		success = node.performAction(AccessibilityNodeInfo.ACTION_CLICK);
	}

	if (!success) {
		node = firstNode;
		showOnScreen(node);
		Point coor = getCoordinates(node);
		debugMe(node);
		success = tap(coor.x, coor.y);
	} 

	if (success) node.refresh();
	if (stepDelay > 0) wait(stepDelay);
	return node;

}


click(int x, int y) {
	return tap(x, y);
}

click(float x, float y) {
	return tap(x, y);

}

click(double x, double y) {
	return tap(x, y);
}

/* Collection Overloads */
click(ArrayList nodes) {
	return click(toNode(nodes));
}

click(ArrayList nodes, int index) {
	return click(toNode(nodeList, index));
}

click(HashMap nodesMap) {
	return click(toNode(nodesMap));
}

click(HashMap nodesMap, String mapKey) {
	return click(toNode(nodesMap, mapKey));
}

/* Basic Search Overloads (Text-based) */
click(String text) {
	return click(getNode(getRoot(), "text", text, 0));
}

click(String text, int index) {
	return click(getNode(getRoot(), "text", text, index));
}

click(String text, long timeout) {
	return click(getNode(getRoot(), "text", text, 0, timeout));
}

click(String text, int index, long timeout) {
	return click(getNode(getRoot(), "text", text, index, timeout));
}

