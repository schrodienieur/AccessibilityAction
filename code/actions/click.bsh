	return click(getNode(getRoot(), key, value, 0));
}

click(String key, String value, int index) {
	return click(getNode(getRoot(), key, value, index));
}

click(String key, String value, int index, long timeout) {
	return click(getNode(getRoot(), key, value, index, timeout));
}

/* Complex Search Overloads (Root and Configs) */
click(AccessibilityNodeInfo root, String value) {
	return click(getNode(root, value));
}

click(String text, Object[][] argsConfigs) {
	return click(getNode(getRoot(), "text", text, 0, waitNodesTimeout, argsConfigs));
}

click(String text, int parentLevel, String nearbyText) {
	return click(getNode(getRoot(), "text", text, 0, waitNodesTimeout, parentLevel, "text", nearbyText));
}

click(String key, String value, int parentLevel, String nearbyText) {
	return click(getNode(getRoot(), key, value, 0, waitNodesTimeout, parentLevel, "text", nearbyText));
}

click(String key, String value, int parentLevel, String nearbyKey, String nearbyValue) {
	return click(getNode(getRoot(), key, value, 0, waitNodesTimeout, parentLevel, nearbyKey, nearbyValue));
}

click(String key, String value, int index, long timeout, int parentLevel, String nearbyKey, String nearbyValue) {
	return click(getNode(getRoot(), key, value, index, timeout, parentLevel, nearbyKey, nearbyValue));
}

/* AccessibilityNodeInfo Root specific variants */
click(AccessibilityNodeInfo root, String key, String value, int index, long timeout) {
	return click(getNode(root, key, value, index, timeout));
}

