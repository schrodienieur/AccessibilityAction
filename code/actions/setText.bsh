	return setText(node, setText);
}

setText(String key, String value, String setText, int index, long timeout) {
	AccessibilityNodeInfo node = getNode(key, value, index, timeout);
	return setText(node, setText);
}

setText(String key, String value, String setText, int parentLevel, String nearbyText) {
	AccessibilityNodeInfo node = getNode(key, value, 0, waitNodesTimeout, parentLevel, "text", nearbyText);
	return setText(node, setText);
}

/* Focus and Special Overloads */
setText(String setText) {
	/* Targets the currently focused input field */
	AccessibilityNodeInfo node = getNode("focus", null);
    return setText(node, setText);
}


setText(String text, String setText, Object[][] argsConfigs) {
	AccessibilityNodeInfo node = getNode("text", text, 0, waitNodesTimeout, argsConfigs);
	return setText(node, setText);
}

setText(String text, String setText, int parentLevel, String nearbyText) {
	AccessibilityNodeInfo node = getNode("text", text, 0, waitNodesTimeout, parentLevel, "text", nearbyText);
	return setText(node, setText);
}

setText(String key, String value, String setText, int parentLevel, String nearbyKey, String nearbyValue) {
	AccessibilityNodeInfo node = getNode(key, value, 0, waitNodesTimeout, parentLevel, nearbyKey, nearbyValue);
	return setText(node, setText);
}


/*───────────────────────────────────────────────────────────────
setText(AccessibilityNodeInfo root, ...)
**New Overloads with Root Entry Parameter**
These methods allow setting setText on nodes found relative to
a specific AccessibilityNodeInfo root instead of the global root.
───────────────────────────────────────────────────────────────*/

/* Complex Search Overloads (Root and Configs) */
