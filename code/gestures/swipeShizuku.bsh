import android.view.MotionEvent;
import android.view.InputDevice;
import android.view.InputEvent;
import android.graphics.Path;
import android.graphics.Paint;
import android.graphics.Canvas;
import android.graphics.Bitmap;
import android.graphics.PixelFormat;
import android.util.DisplayMetrics;
import android.view.WindowManager;
import android.view.Gravity;
import android.widget.ImageView;
import android.content.Context;
import android.os.Handler;
import android.os.Looper;
import android.os.IBinder;
import android.os.SystemClock;
import java.lang.reflect.Method;
import rikka.shizuku.ShizukuBinderWrapper;
import android.hardware.input.IInputManager$Stub$Proxy;
import android.hardware.input.IInputManager$Stub;

/*───────────────────────────────────────────────────────────────
swipeShizuku(double startX, double startY, double endX, double endY, long duration, boolean stopFlick)
**Performs a swipe gesture via Shizuku**
Provides control over momentum (flick) at the end of the gesture.

Arguments:

* startX, startY: Start coordinates (0.0-1.0 for relative, or absolute pixels).
* endX, endY: End coordinates.
* duration: durationation of the swipe in milliseconds.
* stopFlick: If true, pauses at the end to prevent momentum.

Example:
swipeShizuku(0.5, 0.8, 0.5, 0.2, 300, true);
───────────────────────────────────────────────────────────────*/
public boolean swipeShizuku(double startX, double startY, double endX, double endY, long duration, boolean stopFlick) {
	ShizukuBinderWrapper inputBinder = tasker.getShizukuService("input");
	IInputManager$Stub$Proxy iim = IInputManager$Stub.asInterface(inputBinder);
	if (iim == null) return false;

	/* Setup screen metrics */
	WindowManager wm = (WindowManager) context.getSystemService(Context.WINDOW_SERVICE);
	DisplayMetrics dm = new DisplayMetrics();
	wm.getDefaultDisplay().getRealMetrics(dm);
	float screenW = (float) dm.widthPixels;
	float screenH = (float) dm.heightPixels;

	/* Normalize coordinates */
	if (Math.abs((float) startX) <= 1.0f) startX *= screenW;
	if (Math.abs((float) startY) <= 1.0f) startY *= screenH;
	if (Math.abs((float) endX) <= 1.0f) endX *= screenW;
	if (Math.abs((float) endY) <= 1.0f) endY *= screenH;

	try {
		long downTime = SystemClock.uptimeMillis();

		/* 1. ACTION_DOWN */
		MotionEvent evDown = MotionEvent.obtain(downTime, SystemClock.uptimeMillis(), MotionEvent.ACTION_DOWN, (float) startX, (float) startY, 1.0f, 1.0f, 0, 1.0f, 1.0f, 0, 0);
		evDown.setSource(InputDevice.SOURCE_TOUCHSCREEN);
		iim.injectInputEvent(evDown, 1);
		evDown.recycle();

		/* 2. Interpolate ACTION_MOVE */
		int steps = (int) Math.max(2, duration / 16);
		long stepDelay = duration / steps;

		for (int i = 1; i <= steps; i++) {
			float t = (float) i / steps;
			float movendX = startX + (endX - startX) * t;
			float movendY = startY + (endY - startY) * t;
			MotionEvent eventMove = MotionEvent.obtain(downTime, SystemClock.uptimeMillis(), MotionEvent.ACTION_MOVE, (float) movendX, (float) movendY, 1.0f, 1.0f, 0, 1.0f, 1.0f, 0, 0);
			eventMove.setSource(InputDevice.SOURCE_TOUCHSCREEN);
			iim.injectInputEvent(eventMove, 1);
			eventMove.recycle();

			if (stepDelay > 0) Thread.sleep(stepDelay);
		}

		/* 3. Stop Flick Logic */
		if (stopFlick) {
			/* Hold at target to zero out calculated velocity */
			MotionEvent eventHold = MotionEvent.obtain(downTime, SystemClock.uptimeMillis(), MotionEvent.ACTION_MOVE, (float) endX, (float) endY, 1.0f, 1.0f, 0, 1.0f, 1.0f, 0, 0);
			eventHold.setSource(InputDevice.SOURCE_TOUCHSCREEN);
			iim.injectInputEvent(eventHold, 1);
			eventHold.recycle();
			Thread.sleep(60);
		}

		/* 4. ACTION_UP */
		MotionEvent evUp = MotionEvent.obtain(downTime, SystemClock.uptimeMillis(), MotionEvent.ACTION_UP, (float) endX, (float) endY, 1.0f, 1.0f, 0, 1.0f, 1.0f, 0, 0);
		evUp.setSource(InputDevice.SOURCE_TOUCHSCREEN);
		iim.injectInputEvent(evUp, 1);
		evUp.recycle();

		return true;
	} catch (Exception e) {
		tasker.log("swipeShizuku Error: " + e.toString());
		return false;
	}

}

/* Overloaded swipe method */
boolean swipeShizuku(double startX, double startY, double endX, double endY, long duration) {
	return swipeShizuku(startX, startY, endX, endY, duration, false);
}

boolean swipeShizuku(double startX, double startY, double endX, double endY) {
	return swipeShizuku(startX, startY, endX, endY, 10, false);
}

boolean swipeShizuku(double startX, double startY, double endX, double endY, boolean stopFlick) {
	return swipeShizuku(startX, startY, endX, endY, 10, stopFlick);
}

boolean swipeShizuku(double startY, double endY) {
	return swipeShizuku(0.5, startY, 0.5, endY, 10, false);
}

boolean swipeShizuku(double startY, double endY, boolean stopFlick) {
	return swipeShizuku(0.5, startY, 0.5, endY, 10, stopFlick);
}

boolean swipeShizuku(double startY, double endY, long duration) {
	return swipeShizuku(0.5, startY, 0.5, endY, duration, false);
}

boolean swipeShizuku(double startY, double endY, long duration, boolean stopFlick) {
	return swipeShizuku(0.5, startY, 0.5, endY, duration, stopFlick);
}
