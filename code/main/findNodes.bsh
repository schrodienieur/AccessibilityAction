}

List findNodes(AccessibilityNodeInfo root, This multiKeys) {
	if (multiKeys.text == void && multiKeys.id == void) {
		log("Multi keys requires at least 'text' or 'id' " +  multiKeys.variables, "ERROR");
		throw new JavaCodeException("Multi keys requires at least 'text' or 'id'");
	}

	List nodes = new ArrayList();
	boolean oldDebug = debugMe;
	if (oldDebug == true) debugMe = false;
	if (multiKeys.id != void) {
		nodes = findNodes(root, "id", multiKeys.id);
	} else if (multiKeys.text != void) {
		nodes = findNodes(root, "text", multiKeys.text);
	}
	debugMe = oldDebug;
	// Returns empty list if no nodes are found
	if (nodes.isEmpty()) return nodes;

	List matchNodes = new ArrayList();
	for (AccessibilityNodeInfo node: nodes) {
		if (isMatch(node, multiKeys)) {
			matchNodes.add(node);
		}
	}

	if (debugMe) {
		debugMe(matchNodes);
	}
	
	return matchNodes;
}

List findNodes(This multiKeys) {
	return findNodes(getRoot(), multiKeys);
}