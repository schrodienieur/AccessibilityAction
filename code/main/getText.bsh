import android.view.accessibility.AccessibilityNodeInfo;
import android.text.Spanned;
import android.text.style.URLSpan;
import android.text.style.LocaleSpan;
import java.lang.CharSequence;
import java.lang.Class;
import android.view.accessibility.AccessibilityNodeInfo.RangeInfo;

/*───────────────────────────────────────────────────────────────
  getText(AccessibilityNodeInfo node)
  **Smart Waterfall**
  Checks: 
  1. Raw Text 
  2. Raw ContentDescription 
  3. Metadata (URL/etc) in Text 
  4. Metadata (URL/etc) in ContentDescription
 ───────────────────────────────────────────────────────────────*/
getText(AccessibilityNodeInfo node) {

	if (node == null || node == void) return;
	className = node.getClassName();

	// 1. Try raw text
	if (className.equals("android.widget.SeekBar")) {
		return getText(node, "seekbar", "seekbar");
	}
	String res = getText(node, "text", "text");
	if (res.length() > 0) return res;

	// 2. Try raw contentDescription
	res = getText(node, "contentDescription", "contentDescription");
	if (res.length() > 0) return res;

	// 3. Try Spanned/Metadata in text
	res = getText(node, "TextSpan", "text");
	if (res.length() > 0) return res;

	// 4. Try Spanned/Metadata in contentDescription
	return getText(node, "TextSpan", "contentDescription");
}

getText(ArrayList nodes) {
	return getText(toNode(nodes));
}

getText(ArrayList nodes, int index) {
	return getText(toNode(nodes, index));
}

getText(ArrayList nodes, int index, String key) {
	return getText(toNode(nodes, index), key);
}

getText(HashMap nodesMap) {
	return getText(toNode(nodesMap));
}

getText(HashMap nodesMap, String mapKey) {
	return getText(toNode(nodesMap, mapKey));
}

getText(HashMap nodesMap, String mapKey, String key) {
	return getText(toNode(nodesMap, mapKey));
}

/*───────────────────────────────────────────────────────────────
  getText(AccessibilityNodeInfo node, String key)
  Overload for targeted extraction.
  Example: getText(node, "URLSpan")
 ───────────────────────────────────────────────────────────────*/
getText(AccessibilityNodeInfo node, String key) {
	if (node == null || node == void) return;

	// If user asks specifically for raw fields
	if ("text".equals(key)) return getText(node, "text", "text");
	if ("contentDescription".equals(key)) return getText(node, "contentDescription", "contentDescription");

	// Otherwise, check for Spans in both fields automatically
	String val = getText(node, key, "text");
	if (val.length() > 0) return val;
	return getText(node, key, "contentDescription");
}

/*───────────────────────────────────────────────────────────────
  getText(AccessibilityNodeInfo node, String key, String sourceField)
  **Core Logic**
  Handles raw extraction and dynamic Span metadata (mURL, etc.)
 ───────────────────────────────────────────────────────────────*/
getText(AccessibilityNodeInfo node, String key, String sourceField) {
	if (node == null || node == void) return "";

	if ("seekbar".equals(key)) {
		RangeInfo rangeInfo = node.getRangeInfo();
		if (rangeInfo != null) {
			float current = rangeInfo.getCurrent();
			return current.toString();
		}
		return null;
	}

	CharSequence cs = "text".equals(sourceField) ? node.getText() : node.getContentDescription();
	if (cs == null) return "";

	// Handle RAW request (Immediate return of toString)
	if ("text".equals(key) || "contentDescription".equals(key)) {
		return cs.toString();
	}

	// Handle SPAN request (Targeting metadata like mURL)
	if (key != null && key.endsWith("Span")) {
		if (!(cs instanceof android.text.Spanned)) return "";

		android.text.Spanned spanned = (android.text.Spanned) cs;
		Class spanClass = null;
		try {
			if ("TextSpan".equals(key)) {
				spanClass = Object.class; // Match any span
			} else {
				// Load class dynamically (e.g. android.text.style.URLSpan)
				spanClass = java.lang.Class.forName("android.text.style." + key);
			}

			Object[] spans = spanned.getSpans(0, spanned.length(), spanClass);
			if (spans != null && spans.length > 0) {
				Object s = spans[0];

				// EXTRACT METADATA: URLSpan (This gets the mURL field from your JSON)
				if (s instanceof android.text.style.URLSpan) {
					String u = ((android.text.style.URLSpan) s).getURL();
					if (u != null && u.length() > 0) return u;
				}

				// EXTRACT METADATA: LocaleSpan
				if (s instanceof android.text.style.LocaleSpan) {
					return ((android.text.style.LocaleSpan) s).getLocales().toLanguageTags();
				}

				// Fallback to the visible text if no specific metadata extractor exists
				return spanned.toString();
			}
		} catch (Exception e) {
			// Log error or fallback
		}
	}

	return "";
}